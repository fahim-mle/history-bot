# --- Chunking ---
CHUNK_SIZE=700
CHUNK_OVERLAP=100

# --- Paths ---
SOURCE_DIR=raw_sources/
CHROMA_PATH=vector_store/
REGISTRY_PATH=source_registry.json

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
LLM_MODEL=llama3.2:3b

# --- RAG chain ---
# Keep RETRIEVAL_K low (3) to stay within llama3.2:3b ~4k context window.
# Bump to 5 only after verifying no context-limit issues.
RETRIEVAL_K=3
